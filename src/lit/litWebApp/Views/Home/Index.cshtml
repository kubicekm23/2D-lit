@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>2D:Lit</title>
    <link rel="stylesheet" href="/css/game.css" />
</head>
<body>
    <canvas id="gameCanvas"></canvas>
    <canvas id="hudCanvas" style="position:fixed; top:0; left:0; width:100vw; height:100vh; pointer-events:none; z-index:15;"></canvas>

    <!-- HUD -->
    <div id="hud">
        <div id="hud-top-left">
            <div id="hud-speed">SPD: 0 / 0</div>
            <div id="hud-coords">X:0 Y:0</div>
        </div>
        <div id="hud-top-right">
            <div id="hud-fuel">FUEL: 100%</div>
            <div id="hud-hull">HULL: 100%</div>
            <div id="hud-credits">CR: 0</div>
        </div>
        <div id="hud-bottom">
            <div id="hud-station"></div>
        </div>
    </div>

    <!-- Pause menu overlay -->
    <div id="pause-overlay" style="display:none;"></div>

    <!-- Station overlay -->
    <div id="station-overlay" style="display:none;"></div>

    <!-- Stranded overlay -->
    <div id="stranded-overlay" style="display:none;"></div>

    <!-- Docking minigame overlay -->
    <div id="docking-overlay" style="display:none;">
        <canvas id="docking-canvas"></canvas>
    </div>

    <!-- Map overlay -->
    <div id="map-overlay" style="display:none;">
        <div class="map-container">
            <canvas id="map-canvas"></canvas>
            <div id="map-details" style="display:none;"></div>
        </div>
    </div>

    <!-- ATC Notification -->
    <div id="atc-notification" class="atc-hidden">
        <div class="atc-icon">
            <svg viewBox="0 0 64 64" width="48" height="48">
                <rect x="24" y="44" width="16" height="16" fill="none" stroke="black" stroke-width="2"/>
                <rect x="28" y="16" width="8" height="28" fill="none" stroke="black" stroke-width="2"/>
                <rect x="22" y="8" width="20" height="10" fill="none" stroke="black" stroke-width="2"/>
                <line x1="32" y1="2" x2="32" y2="8" stroke="black" stroke-width="2"/>
            </svg>
        </div>
        <div class="atc-content">
            <div class="atc-title">RESTRICTED AIRSPACE</div>
            <div class="atc-message">STOP, this is restricted airspace. To enter press [F], otherwise you will be denied entry and shot down.</div>
        </div>
    </div>

    <script type="module" src="/js/game/main.js"></script>
</body>
</html>
