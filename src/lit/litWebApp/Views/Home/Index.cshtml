@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>2D:Lit</title>
    <link rel="stylesheet" href="/css/game.css" />
</head>
<body>
    <canvas id="gameCanvas"></canvas>

    <!-- HUD -->
    <div id="hud">
        <div id="hud-top-left">
            <div id="hud-speed">SPD: 0 / 0</div>
            <div id="hud-coords">X:0 Y:0</div>
        </div>
        <div id="hud-top-right">
            <div id="hud-fuel">FUEL: 100%</div>
            <div id="hud-credits">CR: 0</div>
        </div>
        <div id="hud-bottom">
            <div id="hud-station"></div>
        </div>
    </div>

    <!-- Station overlay -->
    <div id="station-overlay" style="display:none;"></div>

    <!-- Stranded overlay -->
    <div id="stranded-overlay" style="display:none;"></div>

    <!-- Docking minigame overlay -->
    <div id="docking-overlay" style="display:none;">
        <canvas id="docking-canvas"></canvas>
    </div>

    <!-- Map overlay -->
    <div id="map-overlay" style="display:none;">
        <div class="map-container">
            <canvas id="map-canvas"></canvas>
        </div>
    </div>

    <script type="module" src="/js/game/main.js"></script>
</body>
</html>
